<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LaJess Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --rose: #C9747F;
            --rose-deep: #A85560;
            --rose-light: #F2D0D4;
            --rose-pale: #FCF0F1;
            --gold: #C8A96E;
            --cream: #FDF8F5;
            --charcoal: #2C2424;
            --charcoal-mid: #5A4A4A;
            --charcoal-soft: #9A8A8A;
            --sidebar-w: 240px;
            --topbar-h: 62px;
            --font-display: 'Playfair Display', serif;
            --font-body: 'Nunito', sans-serif;
            --ease: cubic-bezier(0.4,0,0.2,1);
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 22px;
            --transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
            --shadow-card: 0 8px 40px rgba(169,100,100,0.12);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            font-family: var(--font-body);
            background: #f8f4f2;
            color: var(--charcoal);
            font-size: 15px;
        }

        /* ── Sidebar ── */
        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            width: var(--sidebar-w);
            background: var(--charcoal);
            display: flex;
            flex-direction: column;
            z-index: 200;
            transition: transform 0.3s var(--ease);
            overflow-y: auto;
        }

        .sidebar-brand {
            padding: 1.5rem 1.4rem 1.1rem;
            border-bottom: 1px solid rgba(255,255,255,.07);
            flex-shrink: 0;
        }

        .sidebar-brand-name {
            font-family: var(--font-display);
            font-size: 1.35rem;
            font-weight: 800;
            color: white;
            letter-spacing: .02em;
            display: block;
        }

            .sidebar-brand-name span {
                color: var(--rose-light);
            }

        .sidebar-brand-sub {
            font-size: .56rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: rgba(255,255,255,.3);
            margin-top: 2px;
            display: block;
        }

        .sidebar-nav {
            flex: 1;
            padding: .8rem 0;
        }

        .sidebar-section {
            font-size: .54rem;
            letter-spacing: .24em;
            text-transform: uppercase;
            color: rgba(255,255,255,.25);
            padding: .9rem 1.4rem .35rem;
            font-weight: 700;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: .7rem;
            padding: .62rem 1.4rem;
            color: rgba(255,255,255,.5);
            text-decoration: none;
            font-size: .82rem;
            font-weight: 600;
            transition: all .22s;
            border-left: 3px solid transparent;
        }

            .sidebar-link i {
                font-size: .95rem;
                width: 18px;
                text-align: center;
                flex-shrink: 0;
            }

            .sidebar-link:hover {
                color: white;
                background: rgba(255,255,255,.06);
            }

            .sidebar-link.active {
                color: white;
                background: rgba(201,116,127,.15);
                border-left-color: var(--rose);
            }

        .sidebar-footer {
            padding: 1rem 1.4rem;
            border-top: 1px solid rgba(255,255,255,.07);
            flex-shrink: 0;
        }

            .sidebar-footer a {
                display: flex;
                align-items: center;
                gap: .5rem;
                color: rgba(255,255,255,.4);
                text-decoration: none;
                font-size: .78rem;
                font-weight: 500;
                transition: color .22s;
            }

                .sidebar-footer a:hover {
                    color: var(--rose-light);
                }

        /* ── Topbar ── */
        .admin-topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-w);
            right: 0;
            height: var(--topbar-h);
            z-index: 100;
            background: white;
            border-bottom: 1px solid rgba(201,116,127,.12);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            box-shadow: 0 1px 12px rgba(169,100,100,.06);
        }

        .topbar-title {
            font-family: var(--font-display);
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--charcoal);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .topbar-pill {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .32rem .85rem;
            border-radius: 50px;
            background: var(--rose-pale);
            color: var(--rose-deep);
            font-size: .7rem;
            font-weight: 700;
        }

        .topbar-store-btn {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .35rem .9rem;
            border-radius: 50px;
            background: var(--charcoal);
            color: white;
            font-size: .72rem;
            font-weight: 700;
            text-decoration: none;
            transition: background .22s;
        }

            .topbar-store-btn:hover {
                background: var(--rose);
                color: white;
            }

        /* ── Main ── */
        .admin-main {
            margin-left: var(--sidebar-w);
            padding-top: var(--topbar-h);
            min-height: 100vh;
        }

        .admin-content {
            padding: 2rem;
        }

        /* ── Shared component styles used by all admin views ── */
        .admin-card {
            background: white;
            border-radius: var(--radius-lg);
            border: 1px solid rgba(201,116,127,.1);
            overflow: hidden;
        }

        .admin-card-header {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid rgba(201,116,127,.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: .5rem;
        }

        .admin-card-title {
            font-family: var(--font-display);
            font-size: 1rem;
            font-weight: 700;
            color: var(--charcoal);
            display: flex;
            align-items: center;
            gap: .4rem;
        }

        .admin-card-body {
            padding: 1.5rem;
        }

        /* Stat cards */
        .stat-card {
            background: white;
            border-radius: var(--radius-lg);
            padding: 1.4rem 1.5rem;
            border: 1px solid rgba(201,116,127,.1);
            transition: transform .3s var(--ease), box-shadow .3s var(--ease);
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-card);
            }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-bottom: 1rem;
            flex-shrink: 0;
        }

        .stat-num {
            font-family: var(--font-display);
            font-size: 1.9rem;
            font-weight: 800;
            color: var(--charcoal);
            line-height: 1;
            margin-bottom: .3rem;
        }

        .stat-label {
            font-size: .7rem;
            color: var(--charcoal-soft);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
        }

        .stat-sub {
            font-size: .72rem;
            margin-top: .5rem;
        }

        /* Table */
        .admin-table {
            width: 100%;
            border-collapse: collapse;
        }

            .admin-table th {
                font-size: .63rem;
                letter-spacing: .16em;
                text-transform: uppercase;
                color: var(--charcoal-soft);
                font-weight: 700;
                padding: .75rem 1rem;
                background: #fdf8f5;
                border-bottom: 1px solid rgba(201,116,127,.12);
                text-align: left;
                white-space: nowrap;
            }

            .admin-table td {
                padding: .85rem 1rem;
                border-bottom: 1px solid rgba(201,116,127,.07);
                font-size: .84rem;
                color: var(--charcoal-mid);
                vertical-align: middle;
            }

            .admin-table tr:last-child td {
                border-bottom: none;
            }

            .admin-table tr:hover td {
                background: var(--rose-pale);
            }

        /* Status pills */
        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .25rem .75rem;
            border-radius: 50px;
            font-size: .68rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .sp-pending {
            background: #f3e5f5;
            color: #6a1b9a;
        }

        .sp-confirmed {
            background: #e3f2fd;
            color: #1565c0;
        }

        .sp-processing {
            background: #fff3e0;
            color: #e65100;
        }

        .sp-shipped {
            background: #e0f7fa;
            color: #00695c;
        }

        .sp-delivered {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .sp-cancelled {
            background: #fce4e4;
            color: #c62828;
        }

        /* Buttons */
        .btn-admin {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .48rem 1.1rem;
            border-radius: var(--radius-sm);
            font-family: var(--font-body);
            font-size: .78rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: all .22s;
            border: none;
            white-space: nowrap;
        }

        .btn-admin-rose {
            background: var(--rose);
            color: white;
        }

            .btn-admin-rose:hover {
                background: var(--rose-deep);
                color: white;
                transform: translateY(-1px);
            }

        .btn-admin-outline {
            background: transparent;
            color: var(--rose);
            border: 1.5px solid var(--rose);
        }

            .btn-admin-outline:hover {
                background: var(--rose);
                color: white;
            }

        .btn-admin-danger {
            background: #fce4e4;
            color: #c62828;
        }

            .btn-admin-danger:hover {
                background: #c62828;
                color: white;
            }

        .btn-admin-sm {
            padding: .3rem .72rem;
            font-size: .72rem;
        }

        /* Inputs */
        .admin-input {
            width: 100%;
            padding: .58rem .9rem;
            border: 1px solid rgba(201,116,127,.25);
            border-radius: var(--radius-sm);
            font-family: var(--font-body);
            font-size: .84rem;
            color: var(--charcoal);
            outline: none;
            transition: border-color .22s, box-shadow .22s;
            background: white;
        }

            .admin-input:focus {
                border-color: var(--rose);
                box-shadow: 0 0 0 3px rgba(201,116,127,.1);
            }

        .admin-label {
            font-size: .63rem;
            letter-spacing: .16em;
            text-transform: uppercase;
            color: var(--charcoal-soft);
            font-weight: 700;
            display: block;
            margin-bottom: .38rem;
        }

        /* Stock */
        .stock-ok {
            color: #2e7d32;
            font-weight: 700;
        }

        .stock-low {
            color: #e65100;
            font-weight: 700;
        }

        .stock-out {
            color: #c62828;
            font-weight: 700;
        }

        /* Alerts */
        .admin-alert {
            padding: .8rem 1.2rem;
            border-radius: 10px;
            font-size: .84rem;
            display: flex;
            align-items: center;
            gap: .6rem;
            margin-bottom: 1.2rem;
            font-weight: 600;
        }

        .admin-alert-success {
            background: #e8f5e9;
            color: #2e7d32;
            border: 1px solid #c8e6c9;
        }

        .admin-alert-danger {
            background: #fce4e4;
            color: #c62828;
            border: 1px solid #f09595;
        }

        /* Mobile */
        .sidebar-toggle {
            display: none;
            position: fixed;
            top: .85rem;
            left: 1rem;
            z-index: 300;
            background: var(--charcoal);
            color: white;
            border: none;
            border-radius: 8px;
            width: 38px;
            height: 38px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
        }

        @@media (max-width: 991px) {
            .admin-sidebar

        {
            transform: translateX(-100%);
        }

        .admin-sidebar.open {
            transform: translateX(0);
            box-shadow: 4px 0 24px rgba(0,0,0,.25);
        }

        .admin-main {
            margin-left: 0;
        }

        .admin-topbar {
            left: 0;
            padding-left: 3.5rem;
        }

        .sidebar-toggle {
            display: flex;
        }

        .admin-content {
            padding: 1.2rem;
        }

        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Mobile sidebar toggle -->
    <button class="sidebar-toggle" id="sidebarToggle">
        <i class="bi bi-list"></i>
    </button>

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <span class="sidebar-brand-name">La<span>Jess</span></span>
            <span class="sidebar-brand-sub">Admin Panel</span>
        </div>

        <nav class="sidebar-nav">
            @{
                var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            }

            <div class="sidebar-section">Main</div>
            <a class="sidebar-link @(action == "Dashboard" ? "active" : "")"
               asp-controller="Admin" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <div class="sidebar-section">Catalog</div>
            <a class="sidebar-link @(action is "Inventory" or "CreateProduct" or "EditProduct" ? "active" : "")"
               asp-controller="Admin" asp-action="Inventory">
                <i class="bi bi-box-seam"></i> Inventory
            </a>
            <a class="sidebar-link @(action is "Suppliers" or "CreateSupplier" or "EditSupplier" ? "active" : "")"
               asp-controller="Admin" asp-action="Suppliers">
                <i class="bi bi-truck"></i> Suppliers
            </a>

            <div class="sidebar-section">Sales</div>
            <a class="sidebar-link @(action is "Orders" or "OrderDetail" ? "active" : "")"
               asp-controller="Admin" asp-action="Orders">
                <i class="bi bi-bag-check"></i> Orders
            </a>
            <a class="sidebar-link @(action == "Reviews" ? "active" : "")"
               asp-controller="Admin" asp-action="Reviews">
                <i class="bi bi-star"></i> Reviews
            </a>

            <div class="sidebar-section">Site</div>
            <a class="sidebar-link" asp-controller="Home" asp-action="Index" target="_blank">
                <i class="bi bi-arrow-left"></i> Back to Store
            </a>
        </nav>

        <div class="sidebar-footer">
            <a asp-controller="Home" asp-action="Index" target="_blank">
                <i class="bi bi-box-arrow-up-right"></i> View Live Store
            </a>
        </div>
    </aside>

    <!-- ═══ TOPBAR ═══ -->
    <div class="admin-topbar">
        <div class="topbar-title">@ViewData["Title"]</div>
        <div class="topbar-right">
            <span class="topbar-pill">
                <i class="bi bi-circle-fill" style="font-size:.4rem;color:var(--rose);"></i> Admin
            </span>
            <a asp-controller="Home" asp-action="Index" class="topbar-store-btn" target="_blank">
                <i class="bi bi-shop"></i> Store
            </a>
        </div>
    </div>

    <!-- ═══ MAIN CONTENT ═══ -->
    <main class="admin-main">
        <div class="admin-content">

            @if (TempData["Success"] != null)
            {
                <div class="admin-alert admin-alert-success">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="admin-alert admin-alert-danger">
                    <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                </div>
            }

            @RenderBody()

        </div>
    </main>

    <!-- ═══ TOAST ═══ -->
    <div id="adminToast" style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;background:var(--charcoal);color:white;padding:.8rem 1.4rem;border-radius:10px;font-size:.84rem;font-family:var(--font-body);display:flex;align-items:center;gap:.6rem;box-shadow:0 8px 24px rgba(0,0,0,.2);transform:translateY(80px);opacity:0;transition:all .35s cubic-bezier(0.4,0,0.2,1);pointer-events:none;">
        <i class="bi bi-check-circle-fill" style="color:var(--rose-light);"></i>
        <span id="adminToastMsg"></span>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mobile sidebar toggle
        const toggle  = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('adminSidebar');
        toggle.addEventListener('click', e => { e.stopPropagation(); sidebar.classList.toggle('open'); });
        document.addEventListener('click', e => {
            if (!sidebar.contains(e.target) && !toggle.contains(e.target))
                sidebar.classList.remove('open');
        });

        // Toast helper
        function showAdminToast(msg) {
            const t = document.getElementById('adminToast');
            document.getElementById('adminToastMsg').textContent = msg;
            t.style.transform = 'translateY(0)';
            t.style.opacity   = '1';
            setTimeout(() => { t.style.transform = 'translateY(80px)'; t.style.opacity = '0'; }, 3000);
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
