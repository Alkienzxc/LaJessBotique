@model List<Product>
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Inventory";
    var categories = ViewBag.Categories as List<Category> ?? new();
    var search     = ViewBag.Search     as string ?? "";
    var categoryId = ViewBag.CategoryId as int?;
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <form method="get" asp-controller="Admin" asp-action="Inventory" class="d-flex gap-2 flex-wrap">
        <div style="position:relative;">
            <i class="bi bi-search" style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%);color:var(--rose);font-size:.8rem;pointer-events:none;"></i>
            <input type="text" name="search" value="@search" class="admin-input"
                   style="padding-left:2.2rem;width:220px;" placeholder="Search products…" />
        </div>
        <select name="categoryId" class="admin-input" style="width:160px;" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var c in categories)
            {
                <option value="@c.Id" selected="@(categoryId == c.Id)">@c.Name</option>
            }
        </select>
        <button type="submit" class="btn-admin btn-admin-rose"><i class="bi bi-funnel-fill"></i> Filter</button>
        @if (!string.IsNullOrEmpty(search) || categoryId.HasValue)
        {
            <a asp-controller="Admin" asp-action="Inventory" class="btn-admin btn-admin-outline">Clear</a>
        }
    </form>
    <a asp-controller="Admin" asp-action="CreateProduct" class="btn-admin btn-admin-rose">
        <i class="bi bi-plus-lg"></i> Add Product
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <div class="admin-card-title">All Products</div>
        <span style="font-size:.78rem;color:var(--charcoal-soft);">@Model.Count result@(Model.Count!=1?"s":"")</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="admin-table">
            <thead>
                <tr><th>Image</th><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Flags</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><img src="@p.ImageUrl" style="width:46px;height:58px;object-fit:cover;border-radius:8px;" /></td>
                        <td>
                            <div style="font-weight:700;color:var(--charcoal);font-size:.88rem;">@p.Name</div>
                            <div style="font-size:.72rem;color:var(--charcoal-soft);">@p.Sizes</div>
                        </td>
                        <td>
                            <span style="background:var(--rose-pale);color:var(--rose-deep);padding:3px 10px;border-radius:50px;font-size:.7rem;font-weight:700;">@p.Category?.Name</span>
                        </td>
                        <td style="font-weight:700;color:var(--rose-deep);">₱@p.Price.ToString("N0")</td>
                        <td>
                            @if (p.Stock == 0)      { <span class="stock-out">Out of stock</span> }
                            else if (p.Stock <= 5)  { <span class="stock-low">@p.Stock left</span> }
                            else                    { <span class="stock-ok">@p.Stock</span> }
                        </td>
                        <td>
                            <div style="display:flex;gap:.3rem;flex-wrap:wrap;">
                                @if (p.IsFeatured)   { <span style="background:var(--rose);color:white;padding:2px 8px;border-radius:4px;font-size:.62rem;font-weight:700;">Featured</span> }
                                @if (p.IsNewArrival) { <span style="background:var(--charcoal);color:white;padding:2px 8px;border-radius:4px;font-size:.62rem;font-weight:700;">New</span> }
                            </div>
                        </td>
                        <td>
                            <div style="display:flex;gap:.4rem;">
                                <a asp-controller="Admin" asp-action="EditProduct" asp-route-id="@p.Id"
                                   class="btn-admin btn-admin-outline btn-admin-sm"><i class="bi bi-pencil"></i></a>
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id" target="_blank"
                                   class="btn-admin btn-admin-sm" style="background:#e3f2fd;color:#1565c0;"><i class="bi bi-eye"></i></a>
                                <form asp-controller="Admin" asp-action="DeleteProduct" method="post" style="display:inline;"
                                      onsubmit="return confirm('Delete @p.Name? This cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn-admin btn-admin-danger btn-admin-sm"><i class="bi bi-trash3"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" style="text-align:center;padding:3rem;color:var(--charcoal-soft);">No products found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
