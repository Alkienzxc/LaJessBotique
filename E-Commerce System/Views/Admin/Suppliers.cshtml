@model List<Supplier>
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Suppliers";
}

<div class="d-flex justify-content-end mb-4">
    <a asp-controller="Admin" asp-action="CreateSupplier" class="btn-admin btn-admin-rose">
        <i class="bi bi-plus-lg"></i> Add Supplier
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <div class="admin-card-title">All Suppliers</div>
        <span style="font-size:.78rem;color:var(--charcoal-soft);">
            @Model.Count(s=>s.IsActive) active · @Model.Count(s=>!s.IsActive) inactive
        </span>
    </div>
    <div style="overflow-x:auto;">
        <table class="admin-table">
            <thead>
                <tr><th>Supplier</th><th>Contact</th><th>Product Types</th><th>Status</th><th>Added</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>
                            <div style="font-weight:700;color:var(--charcoal);">@s.Name</div>
                            <div style="font-size:.72rem;color:var(--charcoal-soft);">@s.Address</div>
                        </td>
                        <td>
                            <div style="font-weight:600;font-size:.84rem;">@s.ContactPerson</div>
                            <div style="font-size:.72rem;color:var(--charcoal-soft);">@s.Email</div>
                            <div style="font-size:.72rem;color:var(--charcoal-soft);">@s.Phone</div>
                        </td>
                        <td style="font-size:.82rem;color:var(--charcoal-mid);">@s.ProductTypes</td>
                        <td>
                            @if (s.IsActive)
                            { <span class="status-pill sp-delivered"><i class="bi bi-circle-fill" style="font-size:.4rem;"></i> Active</span> }
                            else
                            { <span class="status-pill sp-cancelled"><i class="bi bi-circle-fill" style="font-size:.4rem;"></i> Inactive</span> }
                        </td>
                        <td style="color:var(--charcoal-soft);">@s.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <div style="display:flex;gap:.4rem;">
                                <a asp-controller="Admin" asp-action="EditSupplier" asp-route-id="@s.Id"
                                   class="btn-admin btn-admin-outline btn-admin-sm"><i class="bi bi-pencil"></i></a>
                                <form asp-controller="Admin" asp-action="DeleteSupplier" method="post" style="display:inline;"
                                      onsubmit="return confirm('Delete @s.Name?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit" class="btn-admin btn-admin-danger btn-admin-sm"><i class="bi bi-trash3"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" style="text-align:center;padding:3rem;color:var(--charcoal-soft);">No suppliers yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
