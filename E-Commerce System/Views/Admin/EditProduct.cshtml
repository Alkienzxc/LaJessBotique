@model Product
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var isEdit     = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Product" : "Add Product";
    var categories = ViewBag.Categories as List<Category> ?? new();
}

<div style="max-width:760px;">
    <div class="admin-card">
        <div class="admin-card-header">
            <div class="admin-card-title">
                <i class="bi bi-@(isEdit?"pencil":"plus-lg")" style="color:var(--rose);"></i>
                @(isEdit ? "Edit Product" : "Add New Product")
            </div>
            <a asp-controller="Admin" asp-action="Inventory" class="btn-admin btn-admin-outline btn-admin-sm">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
        <div class="admin-card-body">
            <form asp-controller="Admin" asp-action="@(isEdit?"EditProduct":"CreateProduct")" method="post">
                @Html.AntiForgeryToken()
                @if (isEdit) { <input type="hidden" asp-for="Id" /> <input type="hidden" asp-for="CreatedAt" /> }
                <div class="row g-3">
                    <div class="col-12">
                        <label class="admin-label">Product Name *</label>
                        <input asp-for="Name" class="admin-input" placeholder="e.g. Floral Wrap Blouse" required />
                    </div>
                    <div class="col-md-6">
                        <label class="admin-label">Category *</label>
                        <select asp-for="CategoryId" class="admin-input" required>
                            <option value="">-- Select Category --</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="admin-label">Price (₱) *</label>
                        <input asp-for="Price" type="number" step="0.01" min="0" class="admin-input" required />
                    </div>
                    <div class="col-md-3">
                        <label class="admin-label">Stock *</label>
                        <input asp-for="Stock" type="number" min="0" class="admin-input" required />
                    </div>
                    <div class="col-12">
                        <label class="admin-label">Description *</label>
                        <textarea asp-for="Description" class="admin-input" rows="3" required style="resize:vertical;"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="admin-label">Image URL</label>
                        <input asp-for="ImageUrl" class="admin-input" placeholder="https://images.unsplash.com/…" />
                    </div>
                    <div class="col-md-6">
                        <label class="admin-label">Sizes (comma-separated)</label>
                        <input asp-for="Sizes" class="admin-input" placeholder="XS,S,M,L,XL" />
                    </div>
                    <div class="col-md-6">
                        <label class="admin-label">Colors (comma-separated)</label>
                        <input asp-for="Colors" class="admin-input" placeholder="Rose,White,Black" />
                    </div>
                    <div class="col-md-6">
                        <div style="display:flex;align-items:center;gap:.6rem;padding:.7rem 1rem;background:var(--rose-pale);border-radius:8px;border:1px solid var(--rose-light);">
                            <input asp-for="IsFeatured" type="checkbox" id="isFeatured" style="width:16px;height:16px;accent-color:var(--rose);" />
                            <label for="isFeatured" style="font-size:.85rem;font-weight:600;color:var(--charcoal);cursor:pointer;margin:0;">Featured on Homepage</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div style="display:flex;align-items:center;gap:.6rem;padding:.7rem 1rem;background:#e8f5e9;border-radius:8px;border:1px solid #c8e6c9;">
                            <input asp-for="IsNewArrival" type="checkbox" id="isNew" style="width:16px;height:16px;accent-color:#2e7d32;" />
                            <label for="isNew" style="font-size:.85rem;font-weight:600;color:var(--charcoal);cursor:pointer;margin:0;">Mark as New Arrival</label>
                        </div>
                    </div>
                    <div class="col-12 pt-2">
                        <button type="submit" class="btn-admin btn-admin-rose">
                            <i class="bi bi-@(isEdit?"check-lg":"plus-lg")"></i>
                            @(isEdit ? "Save Changes" : "Add Product")
                        </button>
                        <a asp-controller="Admin" asp-action="Inventory" class="btn-admin btn-admin-outline" style="margin-left:.5rem;">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
