@model List<CartItem>
@{
    ViewData["Title"] = "Your Basket";
    var total = (decimal)(ViewBag.Total ?? 0);
    var shipping = (decimal)(ViewBag.Shipping ?? 150);
    var grandTotal = total + shipping;
}

@section Styles {
    <style>
        .cart-hero {
            background: var(--cream-dark);
            padding: 3rem 0 2rem;
            border-bottom: 1px solid rgba(201,116,127,.1);
        }

        .cart-hero-title {
            font-family: var(--font-display);
            font-size: 2.4rem;
            font-weight: 400;
        }

            .cart-hero-title em {
                font-style: italic;
                color: var(--rose);
            }

        .cart-table {
            width: 100%;
            border-collapse: collapse;
        }

            .cart-table th {
                font-size: .65rem;
                letter-spacing: .2em;
                text-transform: uppercase;
                color: var(--charcoal-soft);
                font-weight: 500;
                padding: .8rem 1rem;
                border-bottom: 1px solid rgba(201,116,127,.15);
                text-align: left;
            }

            .cart-table td {
                padding: 1.2rem 1rem;
                border-bottom: 1px solid rgba(201,116,127,.08);
                vertical-align: middle;
            }

        .cart-item-img {
            width: 80px;
            height: 100px;
            object-fit: cover;
            border-radius: var(--radius-md);
        }

        .cart-item-name {
            font-family: var(--font-display);
            font-size: 1.05rem;
            color: var(--charcoal);
            margin-bottom: .2rem;
        }

        .cart-item-meta {
            font-size: .72rem;
            color: var(--charcoal-soft);
        }

        .cart-qty-wrap {
            display: flex;
            align-items: center;
            gap: .4rem;
        }

        .cart-qty-btn {
            width: 30px;
            height: 30px;
            border: var(--border-rose);
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: .9rem;
            color: var(--charcoal-mid);
            transition: var(--transition);
        }

            .cart-qty-btn:hover {
                background: var(--rose-pale);
                color: var(--rose);
            }

        .cart-qty-val {
            width: 36px;
            text-align: center;
            font-family: var(--font-display);
            font-size: 1rem;
            color: var(--charcoal);
        }

        .cart-remove-btn {
            background: none;
            border: none;
            color: var(--charcoal-soft);
            cursor: pointer;
            font-size: 1rem;
            transition: color .25s;
            padding: .3rem;
        }

            .cart-remove-btn:hover {
                color: var(--rose);
            }

        .cart-subtotal {
            font-family: var(--font-display);
            font-size: 1.05rem;
            font-weight: 500;
            color: var(--charcoal);
        }

        /* Summary */
        .cart-summary {
            background: white;
            border-radius: var(--radius-lg);
            padding: 2rem;
            border: 1px solid rgba(201,116,127,.12);
            position: sticky;
            top: 90px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .6rem 0;
            font-size: .88rem;
            color: var(--charcoal-mid);
        }

            .summary-row.total {
                padding-top: 1rem;
                margin-top: .5rem;
                border-top: 1px solid rgba(201,116,127,.15);
                font-family: var(--font-display);
                font-size: 1.3rem;
                color: var(--charcoal);
                font-weight: 500;
            }

                .summary-row.total span {
                    color: var(--rose-deep);
                }

        .free-shipping-bar {
            background: var(--rose-pale);
            border-radius: var(--radius-sm);
            padding: .7rem 1rem;
            margin-bottom: 1.2rem;
            font-size: .78rem;
            color: var(--rose-deep);
        }

            .free-shipping-bar .progress {
                height: 4px;
                background: var(--rose-light);
                border-radius: 2px;
                margin-top: .4rem;
                overflow: hidden;
            }

            .free-shipping-bar .progress-fill {
                height: 100%;
                background: var(--rose);
                border-radius: 2px;
                transition: width .5s var(--ease);
            }

        /* Empty cart */
        .empty-cart {
            text-align: center;
            padding: 5rem 2rem;
        }
    </style>
}

<div class="cart-hero">
    <div class="container">
        <div style="font-size:.72rem;color:var(--charcoal-soft);margin-bottom:.5rem;">
            <a asp-controller="Home" asp-action="Index" style="color:var(--charcoal-soft);text-decoration:none;">Home</a>
            <span style="margin:0 .5rem;color:var(--rose-light);">›</span>
            <span>Your Basket</span>
        </div>
        <h1 class="cart-hero-title">Your <em>Basket</em></h1>
    </div>
</div>

<div style="background:var(--cream);padding:3rem 0 5rem;">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="empty-cart">
                <div style="font-size:3.5rem;color:var(--rose-light);margin-bottom:1.2rem;">
                    <i class="bi bi-bag"></i>
                </div>
                <h2 style="font-family:var(--font-display);font-size:1.8rem;color:var(--charcoal);margin-bottom:.6rem;">
                    Your basket is empty
                </h2>
                <p style="color:var(--charcoal-soft);margin-bottom:2rem;">
                    Looks like you haven't added anything yet.
                </p>
                <a asp-controller="Product" asp-action="Index" class="btn-rose">
                    <i class="bi bi-bag-heart"></i> Start Shopping
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <!-- Cart Items -->
                <div class="col-lg-8">
                    <div style="background:white;border-radius:var(--radius-lg);padding:1.5rem;border:1px solid rgba(201,116,127,.1);">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h2 style="font-family:var(--font-display);font-size:1.3rem;color:var(--charcoal);">
                                @Model.Count item@(Model.Count != 1 ? "s" : "") in basket
                            </h2>
                            <form asp-controller="Cart" asp-action="Clear" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:none;border:none;font-size:.75rem;color:var(--charcoal-soft);cursor:pointer;text-decoration:underline;">
                                    Clear all
                                </button>
                            </form>
                        </div>

                        <table class="cart-table">
                            <thead>
                                <tr>
                                    <th colspan="2">Product</th>
                                    <th>Size</th>
                                    <th>Quantity</th>
                                    <th>Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td style="width:100px;">
                                            <img src="@item.ImageUrl" alt="@item.ProductName"
                                                 class="cart-item-img" />
                                        </td>
                                        <td>
                                            <div class="cart-item-name">@item.ProductName</div>
                                            <div class="cart-item-meta">@item.CategoryName</div>
                                            <div class="cart-item-meta" style="color:var(--rose);margin-top:2px;">
                                                ₱@item.Price.ToString("N0") each
                                            </div>
                                        </td>
                                        <td>
                                            <span style="font-size:.82rem;color:var(--charcoal-mid);">
                                                @(string.IsNullOrEmpty(item.SelectedSize) ? "—" : item.SelectedSize)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="cart-qty-wrap">
                                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input type="hidden" name="selectedSize" value="@item.SelectedSize" />
                                                    <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                                    <button type="submit" class="cart-qty-btn">−</button>
                                                </form>
                                                <span class="cart-qty-val">@item.Quantity</span>
                                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input type="hidden" name="selectedSize" value="@item.SelectedSize" />
                                                    <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                                    <button type="submit" class="cart-qty-btn">+</button>
                                                </form>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="cart-subtotal">₱@item.SubTotal.ToString("N0")</span>
                                        </td>
                                        <td>
                                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="selectedSize" value="@item.SelectedSize" />
                                                <button type="submit" class="cart-remove-btn" title="Remove">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <a asp-controller="Product" asp-action="Index"
                       class="btn-outline-rose mt-3 d-inline-flex">
                        <i class="bi bi-arrow-left"></i> Continue Shopping
                    </a>
                </div>

                <!-- Summary -->
                <div class="col-lg-4">
                    <div class="cart-summary">
                        <h3 style="font-family:var(--font-display);font-size:1.3rem;margin-bottom:1.2rem;">
                            Order Summary
                        </h3>

                        @{
                            var remaining = 2000 - total;
                        }
                        @if (remaining > 0)
                        {
                            <div class="free-shipping-bar">
                                <span>Add ₱@remaining.ToString("N0") more for free shipping!</span>
                                <div class="progress">
                                    <div class="progress-fill" style="width:@(Math.Min(100, (total / 2000) * 100))%"></div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="free-shipping-bar" style="background:#e8f5e9;color:#2e7d32;">
                                <i class="bi bi-check-circle-fill"></i> You qualify for free shipping!
                            </div>
                        }

                        <div class="summary-row">
                            <span>Subtotal</span>
                            <span>₱@total.ToString("N0")</span>
                        </div>
                        <div class="summary-row">
                            <span>Shipping</span>
                            <span>@(shipping == 0 ? "FREE" : "₱" + shipping.ToString("N0"))</span>
                        </div>
                        <div class="summary-row total">
                            <span>Total</span>
                            <span>₱@grandTotal.ToString("N0")</span>
                        </div>

                        <a asp-controller="Checkout" asp-action="Index"
                           class="btn-rose mt-4" style="width:100%;justify-content:center;padding:1rem;">
                            Proceed to Checkout <i class="bi bi-arrow-right"></i>
                        </a>

                        <div class="d-flex gap-2 justify-content-center mt-3 flex-wrap">
                            <span style="font-size:.7rem;color:var(--charcoal-soft);display:flex;align-items:center;gap:.3rem;">
                                <i class="bi bi-shield-lock" style="color:var(--rose);"></i> Secure Checkout
                            </span>
                            <span style="font-size:.7rem;color:var(--charcoal-soft);display:flex;align-items:center;gap:.3rem;">
                                <i class="bi bi-arrow-return-left" style="color:var(--rose);"></i> Easy Returns
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
