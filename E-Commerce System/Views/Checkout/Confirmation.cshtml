@model Order
@{
    ViewData["Title"] = "Order Confirmed";
}
@section Styles {
    <style>
        .confirm-wrap {
            max-width: 680px;
            margin: 5rem auto;
            text-align: center;
            padding: 0 1rem;
        }

        .confirm-icon {
            width: 80px;
            height: 80px;
            background: var(--rose-pale);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--rose);
            margin: 0 auto 1.5rem;
        }

        .confirm-title {
            font-family: var(--font-display);
            font-size: 2.2rem;
            font-weight: 400;
            color: var(--charcoal);
            margin-bottom: .5rem;
        }

        .confirm-order-num {
            font-size: .85rem;
            color: var(--charcoal-soft);
            margin-bottom: 2rem;
        }

            .confirm-order-num strong {
                color: var(--rose);
                font-size: 1rem;
            }

        .confirm-card {
            background: white;
            border-radius: var(--radius-lg);
            padding: 2rem;
            border: 1px solid rgba(201,116,127,.12);
            text-align: left;
            margin-bottom: 1.5rem;
        }

        .ci-row {
            display: flex;
            justify-content: space-between;
            padding: .5rem 0;
            font-size: .88rem;
            border-bottom: 1px solid rgba(201,116,127,.08);
        }

            .ci-row:last-child {
                border-bottom: none;
            }

        .ci-label {
            color: var(--charcoal-soft);
        }

        .ci-value {
            color: var(--charcoal);
            font-weight: 500;
        }

        /* Tracking steps */
        .track-steps {
            display: flex;
            align-items: flex-start;
            justify-content: center;
            gap: 0;
            margin: 2rem 0;
        }

        .ts {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            position: relative;
        }

            .ts:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 18px;
                left: calc(50% + 18px);
                right: calc(-50% + 18px);
                height: 2px;
                background: rgba(201,116,127,.2);
            }

            .ts.done::after {
                background: var(--rose);
            }

        .ts-dot {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid rgba(201,116,127,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .85rem;
            background: white;
            color: var(--charcoal-soft);
            z-index: 1;
            transition: var(--transition);
        }

        .ts.done .ts-dot {
            background: var(--rose);
            border-color: var(--rose);
            color: white;
        }

        .ts.active .ts-dot {
            background: var(--rose-pale);
            border-color: var(--rose);
            color: var(--rose);
        }

        .ts-label {
            font-size: .62rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--charcoal-soft);
            margin-top: .5rem;
            text-align: center;
        }

        .ts.done .ts-label, .ts.active .ts-label {
            color: var(--rose);
        }
    </style>
}
<div style="background:var(--cream);padding:3rem 0 5rem;">
    <div class="confirm-wrap">
        <div class="confirm-icon"><i class="bi bi-bag-check-fill"></i></div>
        <h1 class="confirm-title">Order Confirmed!</h1>
        <p class="confirm-order-num">
            Thank you, @Model.CustomerName! Your order number is
            <strong>@Model.OrderNumber</strong>
        </p>

        <!-- Tracking progress -->
        <div class="confirm-card">
            <h3 style="font-family:var(--font-display);font-size:1.1rem;margin-bottom:1.2rem;">
                Order Status
            </h3>
            <div class="track-steps">
                @{
                    var steps = new[] { "Confirmed", "Processing", "Shipped", "Delivered" };
                    var step = Model.TrackingStep;
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    var cls = i < step ? "done" : (i == step ? "active" : "");
                    var icon = i < step ? "bi bi-check" : (i == 0 ? "bi bi-check" : i == 1 ? "bi bi-gear" : i == 2 ? "bi bi-truck" : "bi bi-bag-check");
                    <div class="ts @cls">
                        <div class="ts-dot"><i class="@icon"></i></div>
                        <div class="ts-label">@steps[i]</div>
                    </div>
                }
            </div>
        </div>

        <!-- Order details -->
        <div class="confirm-card">
            <h3 style="font-family:var(--font-display);font-size:1.1rem;margin-bottom:1rem;">Order Details</h3>
            <div class="ci-row"><span class="ci-label">Order Number</span><span class="ci-value">@Model.OrderNumber</span></div>
            <div class="ci-row"><span class="ci-label">Date</span><span class="ci-value">@Model.OrderDate.ToString("MMM dd, yyyy")</span></div>
            <div class="ci-row"><span class="ci-label">Ship to</span><span class="ci-value">@Model.ShippingAddress</span></div>
            <div class="ci-row"><span class="ci-label">Total</span><span class="ci-value" style="color:var(--rose-deep);font-family:var(--font-display);font-size:1.05rem;">₱@Model.TotalAmount.ToString("N0")</span></div>
        </div>

        <!-- Items -->
        <div class="confirm-card">
            <h3 style="font-family:var(--font-display);font-size:1.1rem;margin-bottom:1rem;">Items Ordered</h3>
            @foreach (var item in Model.OrderItems)
            {
                <div style="display:flex;align-items:center;gap:.9rem;padding:.7rem 0;border-bottom:1px solid rgba(201,116,127,.08);">
                    <img src="@item.Product?.ImageUrl" style="width:50px;height:62px;object-fit:cover;border-radius:var(--radius-sm);" />
                    <div style="flex:1;">
                        <div style="font-family:var(--font-display);font-size:.95rem;color:var(--charcoal);">@item.Product?.Name</div>
                        <div style="font-size:.72rem;color:var(--charcoal-soft);">Size: @item.SelectedSize · Qty: @item.Quantity</div>
                    </div>
                    <div style="font-family:var(--font-display);color:var(--rose-deep);">₱@item.SubTotal.ToString("N0")</div>
                </div>
            }
        </div>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Checkout" asp-action="Track"
               asp-route-orderNumber="@Model.OrderNumber" class="btn-rose">
                <i class="bi bi-truck"></i> Track Order
            </a>
            <a asp-controller="Product" asp-action="Index" class="btn-outline-rose">
                Continue Shopping
            </a>
        </div>
    </div>
</div>
